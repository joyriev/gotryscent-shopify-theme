  // ===== MULTI-WORD FUZZY SEARCH =====
  function multiWordFuzzyMatch(query, text) {
    const queryWords = normalizeText(query).split(/\s+/);
    const textWords = normalizeText(text).split(/\s+/);
    
    let totalScore = 0;
    let matchedWords = 0;
    
    for (const qWord of queryWords) {
      let bestWordScore = 0;
      for (const tWord of textWords) {
        bestWordScore = Math.max(bestWordScore, fuzzyMatch(qWord, tWord));
      }
      if (bestWordScore > 0) {
        totalScore += bestWordScore;
        matchedWords++;
      }
    }
    
    // Return average score only if all query words found matches
    if (matchedWords === queryWords.length) {
      return totalScore / queryWords.length;
    }
    
    return 0;
  }
  
  // ===== UTFÖR SÖKNING I VÅRA PRODUKTER =====
  function searchProducts(query) {
    if (!query || query.length < 1) return [];
    
    const normalizedQuery = normalizeText(query);
    const queryNoSpaces = normalizedQuery.replace(/\s+/g, '');
    const results = [];
    const addedIds = new Set();
    
    hardcodedProducts.forEach(product => {
      let bestScore = 0;
      const searchText = normalizeText(product.title);
      const searchTextNoSpaces = searchText.replace(/\s+/g, '');
      const normBrand = normalizeText(product.brand);
      const normBrandNoSpaces = normBrand.replace(/\s+/g, '');
      
      // 1. Exact match (högsta poäng)
      if (searchText === normalizedQuery || searchTextNoSpaces === queryNoSpaces) {
        bestScore = 100;
      }
      // 2. Fuzzy match on title
      else {
        const fuzzyTitleScore = multiWordFuzzyMatch(normalizedQuery, product.title);
        if (fuzzyTitleScore > 0) {
          bestScore = Math.max(bestScore, fuzzyTitleScore + 5);
        }
        
        // 3. Fuzzy match on brand
        const fuzzyBrandScore = multiWordFuzzyMatch(normalizedQuery, product.brand);
        if (fuzzyBrandScore > 0) {
          bestScore = Math.max(bestScore, fuzzyBrandScore);
        }
        
        // 3.5 Brand alias match (e.g., "ysl" → "Yves Saint Laurent")
        const queryLower = normalizedQuery.toLowerCase();
        if (brandAliases[queryLower]) {
          const aliasedBrand = brandAliases[queryLower];
          if (normBrand.toLowerCase().includes(aliasedBrand.toLowerCase())) {
            bestScore = Math.max(bestScore, 90);
          }
        }
      }
      
      // 4. Produktnummer match
      if (product.number && product.number === query) {
        bestScore = Math.max(bestScore, 95);
      }
      
      // 5. Sök i searchTerms med fuzzy matching
      if (product.searchTerms && bestScore < 85) {
        for (const term of product.searchTerms) {
          const fuzzyTermScore = multiWordFuzzyMatch(normalizedQuery, term);
          if (fuzzyTermScore > 65) {
            bestScore = Math.max(bestScore, fuzzyTermScore);
          }
        }
      }
      
      // 6. Direkt contains match (fallback)
      if (bestScore < 70) {
        if (searchText.includes(normalizedQuery) || searchTextNoSpaces.includes(queryNoSpaces)) {
          bestScore = Math.max(bestScore, 75);
        }
        if (normBrand.includes(normalizedQuery) || normBrandNoSpaces.includes(queryNoSpaces)) {
          bestScore = Math.max(bestScore, 70);
        }
      }
      
      if (bestScore > 55 && !addedIds.has(product.id)) {
        results.push({ product, score: bestScore });
        addedIds.add(product.id);
      }
    });
    
    return results.sort((a, b) => b.score - a.score);
  }
  
  // ===== SÖK I RIKTIGA PARFYMER =====
  function searchRealPerfumes(query) {
    if (!query || query.length < 1 || !window.SwedishPerfumeCatalog) return [];
    
    const normalizedQuery = normalizeText(query);
    const queryNoSpaces = normalizedQuery.replace(/\s+/g, '');
    const results = [];
    
    for (let brandKey in window.SwedishPerfumeCatalog) {
      if (brandKey.startsWith('_')) continue;
      const perfumes = window.SwedishPerfumeCatalog[brandKey];
      if (!Array.isArray(perfumes)) continue;
      
      perfumes.forEach(perfume => {
        let score = 0;
        const searchName = normalizeText(perfume.name);
        const searchBrand = normalizeText(perfume.brand);
        const searchNameNoSpaces = searchName.replace(/\s+/g, '');
        const searchBrandNoSpaces = searchBrand.replace(/\s+/g, '');
        
        // 1. Exact match
        if (searchName === normalizedQuery || searchNameNoSpaces === queryNoSpaces) {
          score = 100;
        }
        // 2. Fuzzy match on perfume name
        else {
          const fuzzyNameScore = multiWordFuzzyMatch(normalizedQuery, perfume.name);
          if (fuzzyNameScore > 0) {
            score = Math.max(score, fuzzyNameScore + 5);
          }
          
          // 3. Fuzzy match on brand
          const fuzzyBrandScore = multiWordFuzzyMatch(normalizedQuery, perfume.brand);
          if (fuzzyBrandScore > 0) {
            score = Math.max(score, fuzzyBrandScore);
          }
          
          // 3.5 Brand alias match
          const queryLower = normalizedQuery.toLowerCase();
          if (brandAliases[queryLower]) {
            const aliasedBrand = brandAliases[queryLower];
            if (searchBrand.toLowerCase().includes(aliasedBrand.toLowerCase())) {
              score = Math.max(score, 90);
            }
          }
        }
        
        // 4. Product number match
        if (perfume.productNumbers && perfume.productNumbers.some(num => num === query)) {
          score = Math.max(score, 95);
        }
        
        // 5. Fallback: direct contains match
        if (score < 70) {
          if (searchName.includes(normalizedQuery) || searchNameNoSpaces.includes(queryNoSpaces)) {
            score = Math.max(score, 75);
          }
          if (searchBrand.includes(normalizedQuery) || searchBrandNoSpaces.includes(queryNoSpaces)) {
            score = Math.max(score, 70);
          }
        }
        
        if (score > 55) {
          results.push({ perfume, score });
        }
      });
    }
    
    return results.sort((a, b) => b.score - a.score);
  }
  
