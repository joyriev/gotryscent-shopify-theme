  // ===== UTFÖR SÖKNING =====
  function performSearch(query) {
    currentSearchQuery = query;
    content.innerHTML = '<div class="fc-loading">Söker...</div>';
    
    setTimeout(() => {
      const realPerfumes = searchRealPerfumes(query);
      const ourProducts = searchProducts(query);
      
      let html = '';
      
      // Visa riktiga parfymer först
      if (realPerfumes.length > 0) {
        html += `<div class="fc-section-title">Äkta parfymer (${realPerfumes.length})</div>`;
        
        realPerfumes.slice(0, 8).forEach(result => {
          const p = result.perfume;
          html += `
            <div class="fc-real-perfume-item" onclick="window.fcShowPerfumeDetail('${p.id}')">
              <img class="fc-real-perfume-image" src="${p.image}" alt="${p.name}" loading="lazy" onerror="this.src='https://via.placeholder.com/60x60?text=Parfym'">
              <div class="fc-real-perfume-info">
                <div class="fc-real-perfume-name">${p.name}</div>
                <div class="fc-real-perfume-brand">${p.brand}</div>
                <div class="fc-real-perfume-year">${p.year || ''}</div>
              </div>
            </div>
          `;
        });
      }
      
      // Visa våra produkter
      if (ourProducts.length > 0) {
        html += `<div class="fc-section-title">Våra produkter (${ourProducts.length})</div>`;
        
        ourProducts.slice(0, 8).forEach(match => {
          const p = match.product;
          const priceFormatted = (p.price / 100).toFixed(2).replace('.', ',') + ' kr';
          
          html += `
            <div class="fc-real-perfume-item" onclick="window.fcViewDetails('${p.url}')">
              <img class="fc-real-perfume-image" src="${p.image}" alt="${p.title}" loading="lazy" onerror="this.src='https://via.placeholder.com/60x60?text=TryScent'">
              <div class="fc-real-perfume-info">
                <div class="fc-real-perfume-name">${p.title}</div>
                <div class="fc-real-perfume-year">${priceFormatted}</div>
              </div>
            </div>
          `;
        });
      }
      
      if (realPerfumes.length === 0 && ourProducts.length === 0) {
        html = '<div class="fc-no-results">Inga produkter hittades för "' + query + '"</div>';
      }
      
      content.innerHTML = html;
    }, 300);
  }
  
  // ===== SÖKHANTERARE =====
  function handleSearch() {
    const query = searchInput.value.trim();
    
    if (query.length < 1) {
      if (currentView !== 'detail') {
        steps.style.display = 'block';
        content.innerHTML = '';
      }
      return;
    }
    
    steps.style.display = 'none';
    currentView = 'search';
    
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => performSearch(query), 300);
  }
  
  // ===== LÄGG TILL I VARUKORG =====
  window.fcAddToCart = function(variantId, event) {
    if (event) event.stopPropagation();
    
    const btn = event.target;
    const originalText = btn.innerText;
    
    btn.innerText = 'Lägger till...';
    btn.disabled = true;
    
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(response => response.json())
    .then(data => {
      btn.innerText = '✓ Tillagd!';
      btn.style.background = '#2E7D32';
      
      fetch('/cart.js')
        .then(r => r.json())
        .then(cart => {
          updateOfferDisplay(cart.item_count);
          showNotification(`✓ Tillagd! ${cart.item_count}/3 produkter för gratis present`);
        });
      
      setTimeout(() => {
        btn.innerText = originalText;
        btn.style.background = '#C41E3A';
        btn.disabled = false;
      }, 2000);
    })
    .catch(error => {
      btn.innerText = 'Fel';
      setTimeout(() => {
        btn.innerText = originalText;
        btn.disabled = false;
      }, 2000);
    });
  };
  
  // ===== VISA NOTIS =====
  function showNotification(message) {
    let notification = document.querySelector('.fc-notification');
    if (!notification) {
      notification = document.createElement('div');
      notification.className = 'fc-notification';
      document.body.appendChild(notification);
    }
    
    notification.textContent = message;
    notification.classList.add('show');
    
    setTimeout(() => {
      notification.classList.remove('show');
    }, 2000);
  }
  
  // ===== UPPDATERA ERBJUDANDE =====
  function updateOfferDisplay(itemCount) {
    if (!offerStatus || !offerProgress || !offerMessage || !offerSubtext) return;
    
    const percentage = Math.min((itemCount / 3) * 100, 100);
    offerProgress.style.width = percentage + '%';
    
    if (itemCount >= 3) {
      offerStatus.textContent = '🎉 GRATIS!';
      offerSubtext.textContent = 'Du kvalificerar dig för en gratis present!';
      offerMessage.textContent = '🎉 Du kvalificerar dig för en GRATIS present!';
      offerBanner.classList.add('qualified');
    } else {
      const needed = 3 - itemCount;
      offerStatus.textContent = `${itemCount}/3`;
      offerSubtext.textContent = `Lägg till ${needed} fler för en gratis present`;
      offerMessage.textContent = `Lägg till ${needed} fler produkter för en gratis present`;
      offerBanner.classList.remove('qualified');
    }
  }
  
  // ===== HÄMTA VARUKORG =====
  function fetchCartAndUpdate() {
    return fetch('/cart.js')
      .then(response => response.json())
      .then(cart => {
        updateOfferDisplay(cart.item_count);
        return cart;
      })
      .catch(() => ({ item_count: 0 }));
  }
  
  // ===== VISA DETALJER =====
  window.fcViewDetails = function(url) {
    window.location.href = url;
  };
  
  // ===== GÅ TILLBAKA =====
  window.fcGoBack = function() {
    currentView = 'search';
    if (currentSearchQuery.length >= 1) {
      performSearch(currentSearchQuery);
    } else {
      steps.style.display = 'block';
      content.innerHTML = '';
    }
  };
  
  // ===== TOGGLE SÖKRUTA =====
  window.fcToggleSearch = function() {
    if (searchPopup.classList.contains('active')) {
      searchPopup.classList.remove('active');
    } else {
      searchPopup.classList.add('active');
      searchInput.focus();
      fetchCartAndUpdate();
    }
  };
  
  // ===== INIT =====
  document.addEventListener('DOMContentLoaded', function() {
    // ===== MOBILE CART & PRODUCT PAGE DETECTION =====
    function isMobile() {
      // Check ONLY user agent, NOT viewport width
      // This way narrow desktop windows won't be treated as mobile
      return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
    }
    
    function isCartPage() {
      return window.location.pathname.includes('/cart') || window.location.href.includes('/cart');
    }
    
    function isProductPage() {
      return window.location.pathname.includes('/products/') || window.location.pathname.includes('/product/');
    }
    
    function updateSearchButtonVisibility() {
      if (!stickyButton) return;
      
      const mobile = isMobile();
      const onCart = isCartPage();
      const onProduct = isProductPage();
      
      console.log('[updateSearchButtonVisibility]', { mobile, onCart, onProduct, width: window.innerWidth });
      
      // ONLY hide if BOTH: mobile AND (cart OR product)
      if (mobile && (onCart || onProduct)) {
        console.log('[updateSearchButtonVisibility] HIDING - mobile on cart/product');
        stickyButton.setAttribute('style', 'display: none !important;');
        if (searchPopup && searchPopup.classList.contains('active')) {
          searchPopup.classList.remove('active');
        }
      } else {
        // ALWAYS show on desktop (>=769px) regardless of page
        console.log('[updateSearchButtonVisibility] SHOWING - setting display to flex');
        stickyButton.setAttribute('style', 'display: flex !important; visibility: visible !important;');
        stickyButton.classList.remove('hidden');
      }
    }
    
    // Initial check on page load
    updateSearchButtonVisibility();
    
    // Check visibility on window resize (orientation change)
    window.addEventListener('resize', updateSearchButtonVisibility);
    
    // Check visibility when page becomes visible (mobile back navigation)
    document.addEventListener('visibilitychange', function() {
      if (document.visibilityState === 'visible') {
        updateSearchButtonVisibility();
      }
    });
    
    // Detect when user navigates back/forward
    window.addEventListener('popstate', updateSearchButtonVisibility);
    
    // Monitor for dynamic page navigation changes
    let lastPath = window.location.pathname;
    setInterval(function() {
      if (window.location.pathname !== lastPath) {
        lastPath = window.location.pathname;
        setTimeout(updateSearchButtonVisibility, 50);
      }
    }, 1000);
    
    if (searchInput) {
      searchInput.addEventListener('keyup', handleSearch);
    }
    
    if (clearSearch) {
      clearSearch.addEventListener('click', function() {
        searchInput.value = '';
        searchInput.focus();
        steps.style.display = 'block';
        content.innerHTML = '';
        currentView = 'search';
      });
    }
    
    setTimeout(fetchCartAndUpdate, 500);
    
    // Stäng vid klick utanför
    document.addEventListener('click', function(event) {
      if (searchPopup && !searchPopup.contains(event.target) && 
          stickyButton && !stickyButton.contains(event.target) && 
          searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    // Escape-tangent
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && searchPopup && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    // Förhindra att klick inuti popupen stänger den
    if (searchPopup) {
      searchPopup.addEventListener('click', function(e) {
        e.stopPropagation();
      });
    }
  });
  })();
</script>