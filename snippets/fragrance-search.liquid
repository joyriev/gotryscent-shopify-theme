  // ===== NORMALISERA TEXT FÖR SÖKNING (hanterar åäö) =====
  function normalizeText(text) {
    if (!text) return '';
    return text.toLowerCase()
      .replace(/[åä]/g, 'a')
      .replace(/[ö]/g, 'o')
      .replace(/[^a-z0-9]/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();
  }
  
  // ===== FUZZY MATCHING ALGORITHM (Levenshtein Distance) =====
  function fuzzyMatch(input, target) {
    const s = input.toLowerCase();
    const t = target.toLowerCase();
    
    if (s === t) return 100; // Exact match
    if (t.includes(s)) return 85; // Substring match
    if (s.includes(t)) return 80; // Input contains target
    
    // Calculate Levenshtein distance
    const len = Math.max(s.length, t.length);
    const dist = levenshteinDistance(s, t);
    
    // Allow up to 2 character differences for fuzzy matching
    if (dist <= 2 && len > 3) {
      return Math.max(60, 100 - (dist * 15));
    }
    
    return 0;
  }
  
  // ===== LEVENSHTEIN DISTANCE HELPER =====
  function levenshteinDistance(s, t) {
    const d = [];
    for (let i = 0; i <= s.length; i++) {
      d[i] = [i];
    }
    for (let j = 0; j <= t.length; j++) {
      d[0][j] = j;
    }
    for (let i = 1; i <= s.length; i++) {
      for (let j = 1; j <= t.length; j++) {
        const cost = s[i - 1] === t[j - 1] ? 0 : 1;
        d[i][j] = Math.min(
          d[i - 1][j] + 1,      // deletion
          d[i][j - 1] + 1,      // insertion
          d[i - 1][j - 1] + cost // substitution
        );
      }
    }
    return d[s.length][t.length];
  }
  
  // ===== BRAND ALIASES =====
  const brandAliases = {
    'ysl': 'Yves Saint Laurent',
    'dg': 'Dolce & Gabbana',
