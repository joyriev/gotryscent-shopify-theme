    "massive_review_jpzJnz": {
      "type": "massive-review",
      "blocks": {
        "review_CGhLzh": {
          "type": "review",
          "settings": {
            "content": "<p>\"This is my first purchase and I am hooked. I will never purchase perfume from anywhere else again. I could never find a dupe scent that really smelled authentic and consistent.\"</p>",
            "author": "Killian P.",
            "date": "1 day ago",
            "rating": 5,
            "show_verified_badge": true,
            "product": "bergamot-sage-cedar-50-ml"
          }
        },
        "review_QzzUUA": {
          "type": "review",
          "settings": {
            "content": "<p>\"This is the best fragrance I’ve smelt in a very long time the notes drives me insane with happiness. I will keep this in rotation forever.\"</p>",
            "author": "Jenniffer W.",
            "date": "2 days ago",
            "rating": 4,
            "show_verified_badge": true,
            "product": "4x-50ml-perfume-bottles"
          }
        },
        "review_Beinew": {
          "type": "review",
          "settings": {
            "content": "<p>\"All three of the scents I received are very good. Last long and smell as they should. I was only unhappy with the time it took to recieve them. But honestly I made a second order, so just expect a wait. Lol!<br/>\"</p>",
            "author": "Clara P.",
            "date": "2 days ago",
            "rating": 5,
            "show_verified_badge": true,
            "product": "apple-cinnamon-sandalwood"
          }
        },
        "review_dfTye7": {
          "type": "review",
          "disabled": true,
          "settings": {
            "review_image": "shopify://shop_images/dupestore_3221df98-e409-4141-82ec-bdbe62af3756.jpg",
            "content": "<p>\"Been trying to find scents that smell expensive as well as lasted long, to no avail. The fit is exactly what I was looking for..\"</p>",
            "author": "Tiana N.",
            "date": "2 days ago",
            "rating": 4,
            "show_verified_badge": true,
            "product": "fresh-escape-premium"
          }
        },
        "review_PNtt4z": {
          "type": "review",
          "settings": {
            "content": "<p>\"I wasn’t sure what to expect, but this really impressed me. Smells super fresh and honestly pretty close to Aventus. It lasts well and the price is way better.\"</p>",
            "author": "Michael T.",
            "date": "2 days ago",
            "rating": 4,
            "show_verified_badge": true,
            "product": "pineapple-smoke-vanilla-50-ml-1-7-fl-oz"
          }
        },
        "review_wkAn4L": {
          "type": "review",
          "settings": {
            "content": "<p>\"One of my favorite scents. Got to me really fast. Smells so nice.\"</p>",
            "author": "Alex W.",
            "date": "2 days ago",
            "rating": 5,
            "show_verified_badge": true,
            "product": ""
          }
        },
        "review_VPVPkT": {
          "type": "review",
          "settings": {
            "content": "<p>\" I Loooove these perfumes !!! Every single one I got smells divine. Some I would say better than the original .\"</p>",
