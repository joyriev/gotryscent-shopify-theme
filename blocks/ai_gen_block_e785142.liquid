{% doc %}
  @prompt
    Create responsive hero banner without any text or copy or anything like that. I just need to put in the image, which will be both desktop and mobile responsive in the size of : 2048px x 1024 px and 1200 x 1600 for mobile
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-hero-banner-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
  }

  .ai-hero-banner-desktop-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: auto;
  }

  .ai-hero-banner-mobile-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    height: auto;
  }

  .ai-hero-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 2 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-banner-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-hero-banner-placeholder-{{ ai_gen_id }} {
      aspect-ratio: 3 / 4;
    }
  }
{% endstyle %}

<hero-banner-{{ ai_gen_id }}
  class="ai-hero-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-banner-wrapper-{{ ai_gen_id }}">
    {% if block.settings.desktop_image %}
      <img
        src="{{ block.settings.desktop_image | image_url: width: 2048 }}"
        alt="{{ block.settings.desktop_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.desktop_image.width }}"
        height="{{ block.settings.desktop_image.height }}"
        class="ai-hero-banner-desktop-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-hero-banner-placeholder-{{ ai_gen_id }} ai-hero-banner-desktop-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-hero-banner-empty-state-{{ ai_gen_id }}">
          Add desktop image (2048px × 1024px)
        </div>
      </div>
    {% endif %}

    {% if block.settings.mobile_image %}
      <img
        src="{{ block.settings.mobile_image | image_url: width: 1200 }}"
        alt="{{ block.settings.mobile_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.mobile_image.width }}"
        height="{{ block.settings.mobile_image.height }}"
        class="ai-hero-banner-mobile-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-hero-banner-placeholder-{{ ai_gen_id }} ai-hero-banner-mobile-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-hero-banner-empty-state-{{ ai_gen_id }}">
          Add mobile image (1200px × 1600px)
        </div>
      </div>
    {% endif %}
  </div>
</hero-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('hero-banner-{{ ai_gen_id }}', HeroBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Hero banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "paragraph",
      "content": "Recommended size: 2048px × 1024px"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "paragraph",
      "content": "Recommended size: 1200px × 1600px"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
