{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  id="{{ section.id }}"
  class="section-{{ section.id }}-padding"
  style="background-color: {{ section.settings.background_color }}">
  <div class="page-width">
    <div class="[display:grid] gap-6 md:gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <h2 class="text-2xl md:text-4xl font-bold">{{ section.settings.title }}</h2>
        <p class="mt-5 max-w-md text-base leading-8">{{ section.settings.description }}</p>
      </div>
      <div class="border border-solid border-white/10 bg-white p-6 md:p-8">
        <div class="mb-10">
          <div class="!block h-[2px] w-full bg-[linear-gradient(90deg,#226139_0%,#226139ab_50%,#22613900_100%)]"></div>
          <div class="mt-3 flex justify-between font-mono text-sm uppercase tracking-[0.18em]">
            <span>0</span>
            <span>15 min</span>
            <span>4 tim</span>
            <span>12 tim</span>
          </div>
        </div>
        <div class="space-y-8">
          <div class="[display:grid] gap-3 md:grid-cols-[180px_1fr] md:gap-6">
            <h3 class="m-0 tracking-normal font-semibold">ÖPPNING · 0–15 MIN</h3>
            <div>
              <p class="m-0 pb-2 border-0 border-b border-solid border-gray-300">{{ product.metafields.custom.top_notes.value.heading }}</p>
              <p class="mt-3 text-sm mb-0">{{ product.metafields.custom.top_notes.value.description | metafield_text }}</p>
            </div>
          </div>
          <div class="[display:grid] gap-3 md:grid-cols-[180px_1fr] md:gap-6">
            <h3 class="m-0 tracking-normal font-semibold">HJÄRTA · 1–4 TIM</h3>
            <div>
              <p class="m-0 pb-2 border-0 border-b border-solid border-gray-300">{{ product.metafields.custom.middle_notes.value.heading }}</p>
              <p class="mt-3 text-sm mb-0">{{ product.metafields.custom.middle_notes.value.description | metafield_text }}</p>
            </div>
          </div>
          <div class="[display:grid] gap-3 md:grid-cols-[180px_1fr] md:gap-6">
            <h3 class="m-0 tracking-normal font-semibold">BAS · 4–12+ TIM</h3>
            <div>
              <p class="m-0 pb-2 border-0 border-b border-solid border-gray-300">{{ product.metafields.custom.base_notes.value.heading }}</p>
              <p class="mt-3 text-sm mb-0">{{ product.metafields.custom.base_notes.value.description | metafield_text }}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>


{% schema %}
  {
    "name": "Smell Journey 2",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#f7f7f7"
      },
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "subtitle",
        "label": "Subtitle",
        "default": "Doftresan"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "Hur den utvecklas på huden"
      }, {
        "type": "textarea",
        "id": "description",
        "label": "Description",
        "default": "De första 30 sekunderna säljer doften. De nästa 12 timmarna avgör om du fortsätter använda den."
      }, {
        "type": "header",
        "content": "t:sections.all.padding.section_padding_heading"
      }, {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_top",
        "default": 72
      }, {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 72
      }
    ],
    "presets": [
      {
        "name": "Smell Journey 2"
      }
    ]
  }
{% endschema %}